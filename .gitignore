# Exception: Allow test certificates (except integration certs, which are
# regenerated by test/integration/server/generate-certs.sh at test time)
!**/test/**/*.crt
!**/test/**/*.key
!**/test/**/*.pem
!**/testdata/**/*.crt
!**/testdata/**/*.key
!**/testdata/**/*.pem
test/integration/server/certs/

# Exception: Allow JSON files in api directory
!api/**/*.json

