# .dockerignore — keep the build context small.
# Build contexts are the repo root (server + Go/Rust SDK images). Exclude VCS,
# docs, and all language build/test artifacts that are regenerated inside images.

# VCS / CI / editor / OS
.git/
.github/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Documentation
*.md
docs/

# Node (JS/TS SDKs)
node_modules/
**/node_modules/

# Rust build output
target/
**/target/

# Python
**/.venv/
**/venv/
**/__pycache__/
**/.pytest_cache/
*.pyc

# Ruby bundled gems
**/vendor/
**/.bundle/

# .NET build output
**/obj/
api/sdks/csharp/bin/
api/sdks/csharp/**/bin/

# Coverage / test results
coverage/
**/coverage/
**/TestResults/
*.out
*.cover
*.prof
coverage.txt
coverage.html
*.test

# Docker files (avoid recursion)
docker-compose*.yml
