{
  "name": "@go-objstore/client",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for go-objstore with REST, gRPC, and QUIC/HTTP3 support. Ships compiled JavaScript (ESM + CJS) and type declarations, so it is also usable directly from plain JavaScript.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean:dist && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node scripts/fix-esm.cjs",
    "clean": "rm -rf dist coverage node_modules",
    "clean:dist": "rm -rf dist",
    "test": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "proto:generate": "npm run proto:clean && npm run proto:compile",
    "proto:clean": "rm -rf src/generated",
    "proto:compile": "grpc_tools_node_protoc --js_out=import_style=commonjs,binary:src/generated --grpc_out=grpc_js:src/generated --plugin=protoc-gen-grpc=$(which grpc_tools_node_protoc_plugin) -I ../../proto ../../proto/objstore.proto && grpc_tools_node_protoc --plugin=protoc-gen-ts=$(which protoc-gen-ts) --ts_out=grpc_js:src/generated -I ../../proto ../../proto/objstore.proto",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "object-storage",
    "s3",
    "gcs",
    "azure-blob",
    "rest",
    "grpc",
    "quic",
    "http3",
    "typescript",
    "javascript",
    "sdk"
  ],
  "author": "Go ObjectStore Team",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeremyhahn/go-objstore.git",
    "directory": "api/sdks/typescript"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.56.0",
    "grpc_tools_node_protoc_ts": "^5.3.3",
    "grpc-tools": "^1.12.4",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.14",
    "@grpc/proto-loader": "^0.7.10",
    "axios": "^1.16.1",
    "form-data": "^4.0.0",
    "google-protobuf": "^3.21.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "handlebars": "^4.7.9"
  }
}
